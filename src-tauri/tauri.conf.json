{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SubManager",
  "version": "0.1.0",
  "identifier": "com.submanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SubManager",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../asset/icons/icon/32x32.png",
      "../asset/icons/icon/128x128.png",
      "../asset/icons/icon/128x128@2x.png",
      "../asset/icons/icon/icon.icns",
      "../asset/icons/icon/icon.ico"
    ]
  }
}